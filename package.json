{
  "name": "ai-citation-optimizer",
  "private": true,
  "description": "AI Citation Optimizer — cross-platform dev scripts",
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "dev": "node scripts/dev.mjs",
    "lint": "npm run lint:backend && npm run lint:frontend",
    "lint:backend": "node scripts/lint-backend.mjs",
    "lint:frontend": "cd frontend && pnpm lint",
    "typecheck": "cd frontend && pnpm typecheck",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "node scripts/test-backend.mjs",
    "test:backend:integration": "node scripts/test-backend.mjs -m integration",
    "test:frontend": "cd frontend && pnpm test:run",
    "validate": "npm run lint && npm run typecheck && npm run test",
    "prepare": "husky",
    "docker:up": "docker compose up --build",
    "docker:up:detached": "docker compose up --build -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "husky": "^9.1.7"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
