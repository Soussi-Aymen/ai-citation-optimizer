# Reproducible installs — always use the lockfile
lockfile=true
prefer-frozen-lockfile=true

# Enforce Node/pnpm versions declared in package.json
engine-strict=true

# Supply-chain hardening: delay newly published packages (24h)
minimum-release-age=1440

# Block installs of packages with revoked/blocked trust levels
trust-policy=no-downgrade

# Peer dependency handling
auto-install-peers=true
strict-peer-dependencies=false

# Security audit level for `pnpm audit`
audit-level=moderate
